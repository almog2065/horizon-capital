# -------------- Horizon Capital — example env --------------
# Copy to `.env` (gitignored) and edit. For production, prefer Docker
# secrets or vault-injected env vars over a checked-in .env file.

# ---- App identity ----
APP_ENV=prod                  # dev | staging | prod | test
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text

# ---- HTTP ----
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
HOST_HTTP_PORT=8080           # external port nginx publishes to

# ---- LLM (optional — system runs deterministic mocks without a key) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
USE_MOCK_LLM=                 # set to 1 to force mock even with a key

# ---- Observability (Grafana / Prometheus — use when web is down) ----
GRAFANA_PUBLIC_URL=http://127.0.0.1:3000
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=admin

# ---- Observability ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=horizon-capital
LANGSMITH_TRACING=true

# ---- Backends ----
POSTGRES_PASSWORD=horizon
# DATABASE_URL is built from the above in docker-compose. Override locally:
# DATABASE_URL=postgresql+psycopg://horizon:horizon@postgres:5432/horizon
# REDIS_URL=redis://redis:6379/0

# ---- Scheduler ----
RUN_SCHEDULER_IN_API=false    # leave false in multi-container deploy
AUTO_PLAN_SUPERVISION=true
PLAN_SUPERVISION_INTERVAL_SEC=1800
FIRM_BALANCE_INTERVAL_SEC=1800   # ignored when MARKET_CADENCE_ENABLED=true

# ---- Market-hours cadence (operating-cadence §1, America/New_York) ----
MARKET_CADENCE_ENABLED=true
CADENCE_MARKET_OPEN_AUTO_EXECUTE=false   # set true for paper auto-fills (HITL still applies)
SKIP_MARKET_HOURS_CADENCE=false          # dev: run cadence jobs outside 09:30–16:00 ET

# ---- Multi-asset data sources (no API key required) ----
ENABLE_COINGECKO=true         # crypto dossiers (BTC, ETH, ...) via CoinGecko public API
ENABLE_FX_CONTEXT=true        # FX macro context via Frankfurter public API
MCP_MARKET_ENABLED=true       # MCP-equivalent in-process bridge (see docs/mcp-market-data.md)
MCP_COINGECKO_TRENDING=true    # trending coins in idea discovery
MCP_YFINANCE_HISTORY=true     # OHLCV history for agents

# ---- Idea-scan throttling ----
SCAN_MAX_EVALUATE=24          # max names per mechanical-screen pass
SCAN_API_DISCOVERY_COUNT=20   # EDGAR discovery batch size
MANAGER_BOOK_SCORE_WEIGHT=0.12  # weight of manager signals in composite (0..1)

# ---- Security ----
ALLOWED_HOSTS=*
CORS_ORIGINS=
